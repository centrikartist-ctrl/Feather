{
  "name": "@feather/supervisor",
  "version": "0.1.0-alpha",
  "private": true,
  "type": "module",
  "bin": {
    "feather-supervisor": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@feather/core": "workspace:*",
    "@feather/shared": "workspace:*",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
